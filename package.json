{
  "name": "wordwise-korean",
  "version": "0.1.4",
  "description": "Browser extension that adds Kindle Word Wise style annotations for Korean learning",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip && node -e \"const f=require('fs'),v=require('./package.json').version,s=`.output/wordwise-korean-${v}-chrome.zip`;if(f.existsSync(s))f.renameSync(s,s.replace('-chrome.','-chromium.'))\"",
    "zip:firefox": "wxt zip -b firefox",
    "zip:all": "pnpm zip && pnpm zip:firefox",
    "test": "vitest run",
    "test:watch": "vitest",
    "update-counts": "node scripts/update-vocab-counts.mjs",
    "generate-icons": "node scripts/generate-icons.mjs",
    "screenshot": "node scripts/screenshot.mjs",
    "compile": "tsc --noEmit",
    "validate-docs": "node scripts/validate-docs.mjs",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/chrome": "^0.0.260",
    "@vitejs/plugin-vue": "^5.0.4",
    "puppeteer": "^24.37.5",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vitest": "^4.0.18",
    "wxt": "^0.17.10"
  }
}
